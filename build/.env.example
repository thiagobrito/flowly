# Credenciais e configuração da automação de build iOS.
# Copie para build/.env e preencha. NUNCA versione build/.env nem o arquivo .p8.

# Team ID da sua conta Apple Developer (Membership → Team ID). Ex.: A1B2C3D4E5
APPLE_TEAM_ID=

# App Store Connect API Key (Users and Access → Integrations → App Store Connect API)
# - ASC_KEY_ID:    ID da chave (ex.: 2X9R4HXF34)
# - ASC_ISSUER_ID: Issuer ID (UUID no topo da página)
# - ASC_KEY_PATH:  caminho para o arquivo AuthKey_XXXX.p8 baixado
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_PATH=

# Sentry (upload de source maps durante o archive). Também pode ficar em .env.local na raiz.
# Crie em https://sentry.io/settings/account/api/auth-tokens/ (scope: project:releases)
# SENTRY_AUTH_TOKEN=

# Opcionais (normalmente detectados automaticamente):
# BUNDLE_ID=com.flowly-v2.app
# IOS_SCHEME=Flowly
# EXPORT_METHOD=app-store
# EXPO_PUBLIC_API_URL=https://flowly-web-coral.vercel.app/api/v1
# SENTRY_ALLOW_FAILURE=true   # continua o build se o upload falhar
# SENTRY_DISABLE_AUTO_UPLOAD=true  # pula o upload no archive
